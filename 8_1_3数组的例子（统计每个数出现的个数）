#include <stdio.h>
//数组的例子（统计1~9每个数出现的个数）
int main() {
	const int number = 10;		//数组的大小
	int x;
	int count[10];		//数组的大小
	int i;
	for (i = 0; i < number; i++) {		//初始化数组
		count[i] = 0;
	}
	scanf_s("%d", &x);
	while (x != -1) {
		if (x >= 0 && x <= 9) {
			count[x]++;			//数组参与运算
			scanf_s("%d", &x);
		}
	}
	for (i = 0; i < number; i++) {
		printf("%d:%d\n", i, count[i]);
	}

	return(0);
}
