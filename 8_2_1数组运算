#include <stdio.h>
//8_2_1
int main() {
	printf("1、初始化count有十个int类型的数字，第一个为0，后面九个数字未初始化全部为0");
	//1、初始化count有十个int类型的数字，第一个为0，后面九个数字未初始化全部为0
	int count[10] = { 0 };		
	int i;
	for (i = 0; i < 10; i++) {
		printf("%d\n", count[i]);		//输出count数组中第一个到第十个单位的每个数字count[i]
	}
	printf("\n2、集成初始化定位，用[n]在初始化数据中给出定位，没有定位的数据接在前面的位置后面，大多数是0，需要具体位置初始化具体数据。\n");
	//2、集成初始化定位，用[n]在初始化数据中给出定位，没有定位的数据接在前面的位置后面
	//大多数是0，需要具体位置初始化具体数据
	int a[10] = {
		[0] = 2,[2] = 3,6		//用[n]在初始化数据中给出定位，没有定位的数据接在前面的位置后面
	};
	for (i = 0; i < 10; i++) {
		printf("%d:%d\n", i,a[i]);
	}
	//3、使用sizeof(a) / sizeof(a[0])计算数组的单元个数,(总数组大小除以第一个数组大小，sizeof单位为字节)
	//这样的好处是：一旦修改数组中初始的数据，不需要修改遍历的代码
	printf("\n3、使用sizeof(a) / sizeof(a[0])计算数组的单元个数，(总数组大小除以第一个数组大小，sizeof单位为字节)\n");
	int b[] = { 2,4,6,7,1,3,5,9,11,13,23,14,32 };
	int c;
	int o;
	/*printf("b数组总字节为%lu\n", sizeof(b));
	printf("第一个单元为%lu字节\n", sizeof(b[0]));
	printf("总共%lu个单元\n", sizeof(b) / sizeof(b[0]));*/

	//sizeof返回的是size_t类型，正确的格式说明符是%zu，而不是%lu,虽然执行上没问题，修改后如下
	printf("b数组总字节为%zu字节\n", sizeof(b));
	printf("第一个单元为%zu字节\n", sizeof(b[0]));
	printf("总共%zu个单元\n", sizeof(b) / sizeof(b[0]));

	for (c = 0; c < sizeof(b) / sizeof(b[0]); c++) {
		printf("%d\t", b[c]);
	}
	
	return 0;
}
